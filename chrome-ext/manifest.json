{
  "manifest_version": 3,
  "name": "OpenClaw Control UI Enhancer",
  "version": "0.3.0",
  "description": "Enhance OpenClaw Control UI — drag & drop files, ACP status badge",
  "permissions": [
    "nativeMessaging"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:39521/*",
        "http://127.0.0.1:39521/*"
      ],
      "js": ["content.js", "status-badge.js", "queue-enhance.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
